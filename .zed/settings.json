{
  "lsp": {
    "deno": {
      "settings": {
        "deno": {
          "enable": true,
          "enablePaths": ["src", "tools", "lib", "e2e"]
        }
      }
    },
    "json-language-server": {
      "settings": {
        "json": {
          "schemas": [
            {
              "fileMatch": ["deno.json", "deno.jsonc"],
              "url": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json"
            }
          ]
        }
      }
    }
  },
  "languages": {
    "JavaScript": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint"
      ],
      "formatter": "language_server"
    },
    "TypeScript": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint"
      ],
      "formatter": "language_server"
    },
    "TSX": {
      "language_servers": [
        "deno",
        "!typescript-language-server",
        "!vtsls",
        "!eslint"
      ],
      "formatter": "language_server"
    },
    "HTML": {
      "formatter": {
        "external": {
          "command": "deno",
          "arguments": ["fmt", "--ext", "html", "-"]
        }
      }
    },
    "CSS": {
      "formatter": {
        "external": {
          "command": "deno",
          "arguments": ["fmt", "--ext", "css", "-"]
        }
      }
    },
    "YAML": {
      "formatter": {
        "external": {
          "command": "deno",
          "arguments": ["fmt", "--ext", "yaml", "-"]
        }
      }
    }
  }
}
