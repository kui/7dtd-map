{
  "compilerOptions": {
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
  },
  "tasks": {
    "serve": "deno run -A tools/build.ts serve",
    "build": {
      "dependencies": [
        "build:ts",
        "build:json",
        "build:prefab-html",
        "build:copy-map-files",
        "build:font-subsets",
        "build:glyph-markers",
        "build:favicon",
      ],
    },
    "build:glyph-markers": {
      "command": "deno run -A tools/generate-glyph-markers.ts",
      "files": [
        "tools/generate-glyph-markers.ts",
        "tools/lib/utils.ts",
        "lib/glyph-marker.ts",
        "tools/fonts/NotoSansSymbols2-Regular.ttf",
        "tools/fonts/NotoEmojiOld-Regular.ttf",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/heavy-ballot-x.svg",
        "public/heavy-ballot-x-path.json",
        "public/triangular-flag.svg",
        "public/triangular-flag-path.json",
      ],
    },
    "build:favicon": {
      "command": "deno run -A tools/generate-favicon.ts",
      "dependencies": ["build:glyph-markers"],
      "files": [
        "tools/generate-favicon.ts",
        "tools/lib/ico.ts",
        "tools/lib/utils.ts",
        "public/heavy-ballot-x.svg",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/favicon.ico",
      ],
    },
    "build:font-subsets": {
      "command": "deno run -A tools/generate-font-subsets.ts",
      "files": [
        "tools/generate-font-subsets.ts",
        "tools/lib/symbol-chars.ts",
        "tools/fonts/NotoColorEmoji-COLRv1.ttf",
        "tools/fonts/NotoSansSymbols2-Regular.ttf",
        "src/**/*.ts",
        "public/*.html",
        "tools/lib/prefab-html.ts",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/NotoColorEmoji.subset.woff2",
        "public/NotoSansSymbols2.subset.woff2",
      ],
    },
    "build:ts": {
      "command": "deno run -A tools/build.ts",
      "files": [
        "tools/build.ts",
        "src/**/*.ts",
        "lib/**/*.ts",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/*.js",
        "public/*.js.map",
        "public/worker/*.js",
        "public/worker/*.js.map",
        "public/prefabs/*.js",
        "public/prefabs/*.js.map",
      ],
    },
    "build:json": {
      "dependencies": [
        "build:json:prefab-props",
        "build:json:labels",
        "build:json:block-counts",
        "build:json:added-prefabs",
      ],
    },
    "build:json:prefab-props": {
      "command": "deno run -A tools/generate-prefab-properties-jsons.ts",
      "files": [
        "tools/generate-prefab-properties-jsons.ts",
        "tools/lib/**/*.ts",
        "tools/vanilla/Data/Prefabs/*/*.xml",
        "tools/vanilla/Data/Config/rwgmixer.xml",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/prefab-difficulties.json",
        "public/prefab-mesh-sizes.json",
        "public/prefab-density-scores.json",
        "public/district-colors.json",
      ],
    },
    "build:json:labels": {
      "command": "deno run -A tools/generate-labels-jsons.ts",
      "files": [
        "tools/generate-labels-jsons.ts",
        "tools/lib/**/*.ts",
        "tools/vanilla/Data/Config/Localization.csv",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/labels/**/*.json",
      ],
    },
    "build:json:added-prefabs": {
      "command": "deno run -A tools/extract-added-prefabs.ts",
      "files": [
        "tools/extract-added-prefabs.ts",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/prefab-added-versions.json",
      ],
    },
    "build:json:block-counts": {
      "command": "deno run -A tools/generate-prefab-block-counts.ts",
      "files": [
        "tools/generate-prefab-block-counts.ts",
        "tools/lib/**/*.ts",
        "tools/vanilla/Data/Prefabs/*/*.blocks.nim",
        "tools/vanilla/Data/Prefabs/*/*.tts",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/prefab-block-counts.json",
      ],
    },
    "build:prefab-html": {
      "command": "deno run -A tools/generate-prefab-html.ts",
      "files": [
        "tools/generate-prefab-html.ts",
        "tools/lib/**/*.ts",
        "tools/vanilla/Data/Prefabs/*/*.xml",
        "tools/vanilla/Data/Prefabs/*/*.blocks.nim",
        "tools/vanilla/Data/Prefabs/*/*.tts",
        "tools/vanilla/Data/Prefabs/*/*.jpg",
        "tools/vanilla/Data/Config/Localization.csv",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/prefabs/*.html",
        "public/prefabs/*.jpg",
        "public/prefabs/index.json",
      ],
    },
    "build:copy-map-files": {
      "command": "deno run -A tools/copy-map-files.ts",
      "files": [
        "tools/copy-map-files.ts",
        "tools/lib/**/*.ts",
        "lib/map-files.ts",
        "tools/vanilla/Data/Worlds/**/*",
        "deno.jsonc",
        "deno.lock",
      ],
      "output": [
        "public/maps/**/*",
      ],
    },
    "fix": "deno fmt && deno lint --fix",
    "test": "deno test -A --parallel",
    "test:changed": "deno test -A --parallel --changed --permit-no-files",
    // Playwright E2E. The dev server (deno task serve) is launched by
    // Playwright's webServer config and listens on the PORT env var
    // (default 18234). Browsers are auto-installed via the e2e:install
    // dependency. On Linux CI you also need system libraries; run
    // `deno run -A @playwright/test install-deps chromium` once (requires
    // sudo) before `deno task e2e`. The bare `@playwright/test` specifier
    // resolves through the `imports` field, so the version is pinned in a
    // single place.
    "e2e:install": "deno run -A @playwright/test install chromium",
    "e2e": {
      "command": "deno run -A @playwright/test test",
      "dependencies": ["e2e:install"],
    },
    "ci": {
      "dependencies": [
        "ci:lint",
        "ci:fmt-check",
        "ci:type-check",
        "test",
        "e2e",
      ],
    },
    "ci:lint": "deno lint",
    "ci:fmt-check": "deno fmt --check",
    "ci:type-check": "deno check",
  },
  "nodeModulesDir": "auto",
  "workspace": [
    "./lib",
    "./src",
    "./src/test",
    "./src/worker",
    "./tools",
    "./tools/test",
    "./e2e",
  ],
  "imports": {
    "@types/three": "npm:@types/three@^0.185.0",
    "fast-png": "npm:fast-png@^8.0.0",
    "three": "npm:three@~0.185.0",
    "@libs/xml": "jsr:@libs/xml@^7.0.4",
    "csv-parse": "npm:csv-parse@^7.0.1",
    "esbuild": "npm:esbuild@~0.28.0",
    "@web-alchemy/fonttools": "npm:@web-alchemy/fonttools@^1.4.0",
    "opentype.js": "npm:opentype.js@^2.0.0",
    "@resvg/resvg-js": "npm:@resvg/resvg-js@^2.6.2",
    "@std/fs": "jsr:@std/fs@^1.0.24",
    "@std/fs/expand-glob": "jsr:@std/fs@^1.0.24/expand-glob",
    "@deno/esbuild-plugin": "jsr:@deno/esbuild-plugin@^1.2.1",
    "@std/expect": "jsr:@std/expect@^1.0.20",
    "@std/testing": "jsr:@std/testing@^1.0.19",
    "@std/testing/bdd": "jsr:@std/testing@^1.0.19/bdd",
    "@std/testing/mock": "jsr:@std/testing@^1.0.19/mock",
    "@std/testing/time": "jsr:@std/testing@^1.0.19/time",
    "@playwright/test": "npm:@playwright/test@^1.49.0",
  },
  "exclude": [
    "./playwright-report",
    "./test-results",
    "./.claude",
  ],
  "lint": {
    "exclude": ["./public"],
    "rules": {
      "include": [
        "no-non-null-assertion",
        "no-non-null-asserted-optional-chain",
        "eqeqeq",
        "camelcase",
        "default-param-last",
        "no-eval",
        "no-self-compare",
        "no-throw-literal",
      ],
    },
  },
  "fmt": {
    "json.trailingCommas": "jsonc",
    "exclude": [
      "./public/old",
      "./public/maps",
      "./public/**/*.svg",
      "./public/**/*.js",
      "./public/**/*.json",
      "./public/prefabs",
    ],
  },
}
